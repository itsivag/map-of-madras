# Browserless (legacy - use Crawl4AI instead)
BROWSERLESS_API_KEY=
BROWSERLESS_BASE_URL=https://production-sfo.browserless.io

# Crawl4AI (recommended - self-hosted, no API costs)
# Set CRAWL4AI_URL to use Crawl4AI instead of Browserless
# Example: http://localhost:11235 (local) or http://crawl4ai:11235 (Docker)
CRAWL4AI_URL=
CRAWL4AI_TOKEN=

AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
BEDROCK_TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_MINIMAX_MODEL_ID=minimax.minimax-m2.1
