{
  "name": "map-of-madras",
  "version": "1.0.0",
  "description": "Map of Madras with hourly Chennai crime ingestion",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "dev:api": "node --watch src/server.js",
    "dev:web": "node scripts/prepare-runtime-config.mjs --default-api-base-url=http://localhost:3000 && next dev --port 3001",
    "start": "node src/server.js",
    "build:web": "node scripts/prepare-runtime-config.mjs && next build",
    "build:hosting": "npm run build:web",
    "deploy:hosting": "npm run build:hosting && firebase deploy --only hosting",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "leaflet",
    "chennai",
    "crime-map",
    "osm"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1008.0",
    "@langchain/textsplitters": "^1.0.1",
    "@qdrant/js-client-rest": "^1.17.0",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "next": "^16.1.6",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "firebase-tools": "^15.10.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
