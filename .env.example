FRONTEND_API_BASE_URL=https://backend-production-a0f6.up.railway.app
FIREBASE_PROJECT_ID=chennai-gbu-map
FIREBASE_TOKEN=

# Pipeline mode: 'semantic' (vector-based) or 'simple' (direct LLM)
# Set USE_SIMPLE_PIPELINE=true to use the simplified Crawl4AI + Direct LLM pipeline
USE_SIMPLE_PIPELINE=false

# Legacy semantic pipeline settings (used when USE_SIMPLE_PIPELINE=false)
PIPELINE_MODE=semantic
SEMANTIC_PUBLISH_THRESHOLD=0.65
RSS_MAX_ITEMS_PER_FEED=25
INGEST_MAX_ITEMS_PER_SOURCE=25
MANUAL_INGEST_LOOKBACK_HOURS=24
INGEST_WINDOW_OVERLAP_MINUTES=30
INGEST_SOURCE_TIME_BUDGET_MS=90000
INGEST_ITEM_TIMEOUT_MS=20000
INGEST_RUN_TIME_BUDGET_MS=300000

# Simplified pipeline settings (used when USE_SIMPLE_PIPELINE=true)
EXTRACTION_CONFIDENCE_THRESHOLD=0.65
CRAWL4AI_MAX_ARTICLES=8

# General ingestion settings
CORS_ALLOWED_ORIGINS=*
ADMIN_TOKEN=

# Crawl4AI (required for simple pipeline, optional for semantic)
# Set CRAWL4AI_URL to enable article extraction
# Example: http://localhost:11235 (local) or http://crawl4ai:11235 (Docker)
CRAWL4AI_URL=
CRAWL4AI_TOKEN=

# Legacy Browserless (deprecated - use Crawl4AI instead)
BROWSERLESS_API_KEY=
BROWSERLESS_BASE_URL=https://production-sfo.browserless.io

# AWS Bedrock (required for both pipelines)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# LLM Model for extraction (used by both pipelines)
BEDROCK_MINIMAX_MODEL_ID=minimax.minimax-m2.1

# Vector embeddings (only needed for semantic pipeline)
BEDROCK_TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Qdrant vector database (only needed for semantic pipeline)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_ARTICLE_COLLECTION=article_chunks_v1
QDRANT_TAXONOMY_COLLECTION=crime_taxonomy_v1
SEMANTIC_PROMPT_VERSION=semantic-v1
